{
  "buildCommand": "pnpm --filter @workspace/telegram-gallery run build",
  "outputDirectory": "artifacts/telegram-gallery/dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_SERVICE_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
