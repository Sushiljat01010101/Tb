{
  "buildCommand": "pnpm install && pnpm --filter @workspace/telegram-gallery run build",
  "outputDirectory": "artifacts/telegram-gallery/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tb-lxbn.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
